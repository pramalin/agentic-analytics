# Copy this file to .env and fill in values for whichever provider overlay
# you're using. .env itself must never be committed.

# compose.docker-model-runner.yaml needs no variables here at all — Compose
# injects LLM_URL / LLM_MODEL automatically. To change the model, edit the
# `models: llm: model:` line in that file directly.

# Only needed for: docker compose -f compose.yaml -f compose.anthropic.yaml up
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-sonnet-5

# Only needed for: docker compose -f compose.yaml -f compose.openai.yaml up
# Separate account/billing from a ChatGPT Plus/Pro subscription — get one at
# platform.openai.com, not chatgpt.com.
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# Only needed for: docker compose -f compose.yaml -f compose.ollama.yaml up
# (optional override — llama3.2 is the default if unset)
OLLAMA_MODEL_NAME=llama3.2
